# Banco de dados
DB_NAME=pedidosdb
DB_USER=postgres
DB_PASSWORD=troque_esta_senha_local

# Pagamentos (gateway externo)
PAYMENT_GATEWAY_URL=https://sandbox.pagamentos.com
PAYMENT_API_KEY=sua-chave-sandbox

# Grafana
GRAFANA_PASSWORD=admin
